---
// Fixed top bar: logo + pride-flag LED dots, section nav, calm toggle,
// and the master addressable RGB strip beneath.
---
<header data-header style="position:fixed;top:0;left:0;right:0;z-index:80;backdrop-filter:blur(8px);background:linear-gradient(var(--bg,#070709),transparent);">
  <div style="display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:16px 28px 12px;">
    <a href="#top" data-hov style="justify-self:start;display:flex;align-items:center;gap:10px;font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.18em;">
      <span data-logo-dots style="display:inline-flex;align-items:center;gap:3px;">
        <span style="width:6px;height:6px;border-radius:50%;background:#ff2a45;color:#ff2a45;animation:ledPulse 1.4s infinite;"></span>
        <span style="width:6px;height:6px;border-radius:50%;background:#15e0a0;color:#15e0a0;animation:ledPulse 1.4s .2s infinite;"></span>
        <span style="width:6px;height:6px;border-radius:50%;background:#2a9dff;color:#2a9dff;animation:ledPulse 1.4s .4s infinite;"></span>
      </span>
      <span style="font-weight:700;">Alie Gonzalez-Guyon</span>
    </a>
    <nav data-nav style="justify-self:center;display:flex;align-items:center;gap:26px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.16em;">
      <a href="#work" data-hov data-click style="color:var(--muted,#7c7e8a);">01/WORK</a>
      <a href="#about" data-hov data-click style="color:var(--muted,#7c7e8a);">02/ABOUT</a>
      <a href="#stack" data-hov data-click style="color:var(--muted,#7c7e8a);">03/STACK</a>
      <a href="#contact" data-hov data-click style="color:var(--muted,#7c7e8a);">04/CONTACT</a>
    </nav>
    <div style="justify-self:end;display:flex;align-items:center;gap:14px;">
      <button data-calm-toggle type="button" aria-label="Reduce motion" aria-pressed="false" title="Reduce motion — calmer animations" style="display:flex;align-items:center;gap:8px;background:var(--panel,#0c0d11);border:1px solid var(--line,#23242e);padding:6px 8px 6px 12px;cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.14em;color:var(--ink,#f3f4f8);">
        <span data-calm-label style="min-width:38px;text-align:left;">FULL</span>
        <span style="position:relative;width:34px;height:18px;border-radius:10px;background:var(--ledoff,#15161d);border:1px solid var(--line,#23242e);">
          <span data-calm-knob style="position:absolute;top:1px;left:1px;width:14px;height:14px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 8px var(--red,#ff2a45);transition:transform .25s cubic-bezier(.2,.7,.2,1);"></span>
        </span>
      </button>
    </div>
  </div>
  <canvas data-strip data-phase="0" style="display:block;width:100%;height:10px;"></canvas>
</header>

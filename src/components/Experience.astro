---
// Experience: career timeline. The ledFlow marquee bars keep inline styles so
// the [style*="ledFlow"] calm rule can disable them.
---
<section aria-labelledby="experience-heading" style="position:relative;z-index:2;border-top:1px solid var(--line,#23242e);background:var(--panel,#0c0d11);">
  <h2 id="experience-heading" class="sr-only">Experience</h2>
  <div style="max-width:1280px;margin:0 auto;padding:90px 28px;">
    <div style="display:flex;align-items:baseline;justify-content:space-between;gap:16px;flex-wrap:wrap;">
      <span data-reveal style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.2em;color:var(--muted,#7c7e8a);">CAREER&nbsp;TIMELINE</span>
      <div data-reveal style="display:flex;gap:20px;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.14em;color:var(--muted,#7c7e8a);">
        <span style="display:flex;align-items:center;gap:7px;"><span style="width:7px;height:7px;border-radius:50%;background:var(--red,#ff2a45);color:var(--red,#ff2a45);animation:ledPulse 1.4s infinite;"></span>LIVE</span>
        <span style="display:flex;align-items:center;gap:7px;"><span style="width:7px;height:7px;border-radius:50%;background:#6b6e7c;"></span>PAST</span>
      </div>
    </div>
    <div style="margin-top:36px;display:flex;flex-direction:column;">

      <div data-reveal data-hov style="display:grid;grid-template-columns:248px 1fr;gap:24px;align-items:center;padding:13px 0;border-top:1px solid var(--line,#23242e);">
        <div>
          <div style="font-family:'Space Grotesk',sans-serif;font-size:18px;font-weight:700;letter-spacing:-.01em;color:var(--ink,#f3f4f8);">Always in Flux Industries</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.06em;color:var(--muted,#9a9aa2);margin-top:4px;">Creative Technologist / Founder · <span style="color:var(--red,#ff2a45);">2022–NOW</span></div>
        </div>
        <div style="position:relative;height:14px;">
          <div style="position:absolute;inset:0;border-radius:3px;background-image:repeating-linear-gradient(90deg,var(--ledoff,#15161d) 0 7px,transparent 7px 12px);opacity:.6;"></div>
          <div style="position:absolute;top:0;bottom:0;left:66.67%;width:33.33%;border-radius:3px;background-image:repeating-linear-gradient(90deg,#ff2a45 0 7px,transparent 7px 12px);background-size:12px 100%;box-shadow:0 0 12px -1px #ff2a45;animation:ledFlow .9s linear infinite;"></div>
        </div>
      </div>

      <div data-reveal data-hov style="display:grid;grid-template-columns:248px 1fr;gap:24px;align-items:center;padding:13px 0;border-top:1px solid var(--line,#23242e);">
        <div>
          <div style="font-family:'Space Grotesk',sans-serif;font-size:18px;font-weight:700;letter-spacing:-.01em;color:var(--ink,#f3f4f8);">hello_miami</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.06em;color:var(--muted,#9a9aa2);margin-top:4px;">Co-Founder · <span style="color:var(--red,#ff2a45);">2024–NOW</span></div>
        </div>
        <div style="position:relative;height:14px;">
          <div style="position:absolute;inset:0;border-radius:3px;background-image:repeating-linear-gradient(90deg,var(--ledoff,#15161d) 0 7px,transparent 7px 12px);opacity:.6;"></div>
          <div style="position:absolute;top:0;bottom:0;left:83.33%;width:16.67%;border-radius:3px;background-image:repeating-linear-gradient(90deg,#ff2a45 0 7px,transparent 7px 12px);background-size:12px 100%;box-shadow:0 0 12px -1px #ff2a45;animation:ledFlow .9s linear infinite;"></div>
        </div>
      </div>

      <div data-reveal data-hov style="display:grid;grid-template-columns:248px 1fr;gap:24px;align-items:center;padding:13px 0;border-top:1px solid var(--line,#23242e);">
        <div>
          <div style="font-family:'Space Grotesk',sans-serif;font-size:18px;font-weight:700;letter-spacing:-.01em;color:var(--ink,#f3f4f8);">SparkFun Electronics</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.06em;color:var(--muted,#9a9aa2);margin-top:4px;">Services Manager · 2021–2022</div>
        </div>
        <div style="position:relative;height:14px;">
          <div style="position:absolute;inset:0;border-radius:3px;background-image:repeating-linear-gradient(90deg,var(--ledoff,#15161d) 0 7px,transparent 7px 12px);opacity:.6;"></div>
          <div style="position:absolute;top:0;bottom:0;left:58.33%;width:8.33%;border-radius:3px;background-image:repeating-linear-gradient(90deg,#6b6e7c 0 7px,transparent 7px 12px);background-size:12px 100%;box-shadow:0 0 7px -2px #6b6e7c;"></div>
        </div>
      </div>

      <div data-reveal data-hov style="display:grid;grid-template-columns:248px 1fr;gap:24px;align-items:center;padding:13px 0;border-top:1px solid var(--line,#23242e);">
        <div>
          <div style="font-family:'Space Grotesk',sans-serif;font-size:18px;font-weight:700;letter-spacing:-.01em;color:var(--ink,#f3f4f8);">MATRIX Labs</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.06em;color:var(--muted,#9a9aa2);margin-top:4px;">Co-Founder &amp; Product Manager · 2016–2021</div>
        </div>
        <div style="position:relative;height:14px;">
          <div style="position:absolute;inset:0;border-radius:3px;background-image:repeating-linear-gradient(90deg,var(--ledoff,#15161d) 0 7px,transparent 7px 12px);opacity:.6;"></div>
          <div style="position:absolute;top:0;bottom:0;left:16.67%;width:41.67%;border-radius:3px;background-image:repeating-linear-gradient(90deg,#6b6e7c 0 7px,transparent 7px 12px);background-size:12px 100%;box-shadow:0 0 7px -2px #6b6e7c;"></div>
        </div>
      </div>

      <div data-reveal data-hov style="display:grid;grid-template-columns:248px 1fr;gap:24px;align-items:center;padding:13px 0;border-top:1px solid var(--line,#23242e);border-bottom:1px solid var(--line,#23242e);">
        <div>
          <div style="font-family:'Space Grotesk',sans-serif;font-size:18px;font-weight:700;letter-spacing:-.01em;color:var(--ink,#f3f4f8);">AdMobilize</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.06em;color:var(--muted,#9a9aa2);margin-top:4px;">Innovation Manager · 2014–2021</div>
        </div>
        <div style="position:relative;height:14px;">
          <div style="position:absolute;inset:0;border-radius:3px;background-image:repeating-linear-gradient(90deg,var(--ledoff,#15161d) 0 7px,transparent 7px 12px);opacity:.6;"></div>
          <div style="position:absolute;top:0;bottom:0;left:0%;width:58.33%;border-radius:3px;background-image:repeating-linear-gradient(90deg,#6b6e7c 0 7px,transparent 7px 12px);background-size:12px 100%;box-shadow:0 0 7px -2px #6b6e7c;"></div>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:248px 1fr;gap:24px;margin-top:16px;">
        <div></div>
        <div style="position:relative;height:16px;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.04em;color:var(--muted,#7c7e8a);">
          <span style="position:absolute;left:0;">2014</span>
          <span style="position:absolute;left:16.67%;transform:translateX(-50%);">2016</span>
          <span style="position:absolute;left:33.33%;transform:translateX(-50%);">2018</span>
          <span style="position:absolute;left:50%;transform:translateX(-50%);">2020</span>
          <span style="position:absolute;left:66.67%;transform:translateX(-50%);">2022</span>
          <span style="position:absolute;left:83.33%;transform:translateX(-50%);">2024</span>
          <span style="position:absolute;right:0;color:var(--red,#ff2a45);">NOW</span>
        </div>
      </div>

    </div>
  </div>
</section>

---
// Stack: 4 "vertical" cards, skill chip groups, the LIVE RGB MATRIX canvas
// (data-grid-canvas — the engine renders its 8 cycling patterns here), and the
// generalist quote.
---
<section id="stack" style="position:relative;z-index:2;max-width:1280px;margin:0 auto;padding:110px 28px;">
  <div data-reveal style="display:flex;align-items:baseline;justify-content:space-between;gap:16px;margin-bottom:44px;border-bottom:1px solid var(--line,#23242e);padding-bottom:18px;">
    <h2 style="margin:0;font-size:clamp(30px,5vw,64px);font-weight:700;letter-spacing:-.02em;">What I Build</h2>
    <span style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.18em;color:var(--muted,#7c7e8a);">[ 04 VERTICALS ]</span>
  </div>

  <div data-cols="verticals" style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;">

    <div data-card data-reveal style="position:relative;display:flex;flex-direction:column;border:1px solid var(--line,#23242e);background:var(--panel,#0c0d11);border-radius:6px;padding:24px 22px;overflow:hidden;">
      <span style="position:absolute;left:0;top:0;bottom:0;width:3px;background-image:repeating-linear-gradient(180deg,var(--red,#ff2a45) 0 7px,transparent 7px 13px);box-shadow:0 0 8px var(--red,#ff2a45);opacity:.5;"></span>
      <div style="display:flex;align-items:flex-start;justify-content:space-between;">
        <div style="display:grid;grid-template-columns:repeat(3,9px);gap:7px;">
          <span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--ledoff,#15161d);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span>
          <span style="width:9px;height:9px;border-radius:50%;background:var(--ledoff,#15161d);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--ledoff,#15161d);"></span>
          <span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--ledoff,#15161d);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span>
        </div>
        <span data-corner style="width:8px;height:8px;border-radius:50%;background:var(--red,#ff2a45);color:var(--red,#ff2a45);"></span>
      </div>
      <span style="margin-top:22px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.16em;color:var(--muted,#7c7e8a);">01 / VERTICAL</span>
      <h3 style="margin:9px 0 0;font-size:19px;font-weight:600;line-height:1.2;">Electronic Product Design</h3>
      <p style="margin:11px 0 16px;font-size:13px;line-height:1.55;color:var(--muted,#9a9aa2);flex:1;">Schematics, PCB layout and microcontroller firmware — building custom electronics through to working-prototype stage.</p>
      <div style="display:flex;flex-wrap:wrap;gap:7px;">
        <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.06em;color:var(--muted,#9a9aa2);border:1px solid var(--line,#23242e);padding:5px 9px;border-radius:3px;">PCB</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.06em;color:var(--muted,#9a9aa2);border:1px solid var(--line,#23242e);padding:5px 9px;border-radius:3px;">FIRMWARE</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.06em;color:var(--muted,#9a9aa2);border:1px solid var(--line,#23242e);padding:5px 9px;border-radius:3px;">ENCLOSURE</span>
      </div>
    </div>

    <div data-card data-reveal style="position:relative;display:flex;flex-direction:column;border:1px solid var(--line,#23242e);background:var(--panel,#0c0d11);border-radius:6px;padding:24px 22px;overflow:hidden;">
      <span style="position:absolute;left:0;top:0;bottom:0;width:3px;background-image:repeating-linear-gradient(180deg,var(--red,#ff2a45) 0 7px,transparent 7px 13px);box-shadow:0 0 8px var(--red,#ff2a45);opacity:.5;"></span>
      <div style="display:flex;align-items:flex-start;justify-content:space-between;">
        <div style="display:grid;grid-template-columns:repeat(3,9px);gap:7px;">
          <span style="width:9px;height:9px;border-radius:50%;background:var(--ledoff,#15161d);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--ledoff,#15161d);"></span>
          <span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span>
          <span style="width:9px;height:9px;border-radius:50%;background:var(--ledoff,#15161d);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--ledoff,#15161d);"></span>
        </div>
        <span data-corner style="width:8px;height:8px;border-radius:50%;background:var(--red,#ff2a45);color:var(--red,#ff2a45);"></span>
      </div>
      <span style="margin-top:22px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.16em;color:var(--muted,#7c7e8a);">02 / VERTICAL</span>
      <h3 style="margin:9px 0 0;font-size:19px;font-weight:600;line-height:1.2;">Fabrication</h3>
      <p style="margin:11px 0 16px;font-size:13px;line-height:1.55;color:var(--muted,#9a9aa2);flex:1;">CAD modeling in Fusion 360 through CNC, laser and 3D printing — turning ideas into real, physical objects.</p>
      <div style="display:flex;flex-wrap:wrap;gap:7px;">
        <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.06em;color:var(--muted,#9a9aa2);border:1px solid var(--line,#23242e);padding:5px 9px;border-radius:3px;">FUSION&nbsp;360</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.06em;color:var(--muted,#9a9aa2);border:1px solid var(--line,#23242e);padding:5px 9px;border-radius:3px;">CNC</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.06em;color:var(--muted,#9a9aa2);border:1px solid var(--line,#23242e);padding:5px 9px;border-radius:3px;">LASER</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.06em;color:var(--muted,#9a9aa2);border:1px solid var(--line,#23242e);padding:5px 9px;border-radius:3px;">3D&nbsp;PRINT</span>
      </div>
    </div>

    <div data-card data-reveal style="position:relative;display:flex;flex-direction:column;border:1px solid var(--line,#23242e);background:var(--panel,#0c0d11);border-radius:6px;padding:24px 22px;overflow:hidden;">
      <span style="position:absolute;left:0;top:0;bottom:0;width:3px;background-image:repeating-linear-gradient(180deg,var(--red,#ff2a45) 0 7px,transparent 7px 13px);box-shadow:0 0 8px var(--red,#ff2a45);opacity:.5;"></span>
      <div style="display:flex;align-items:flex-start;justify-content:space-between;">
        <div style="display:grid;grid-template-columns:repeat(3,9px);gap:7px;">
          <span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span>
          <span style="width:9px;height:9px;border-radius:50%;background:var(--ledoff,#15161d);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--ledoff,#15161d);"></span>
          <span style="width:9px;height:9px;border-radius:50%;background:var(--ledoff,#15161d);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--ledoff,#15161d);"></span>
        </div>
        <span data-corner style="width:8px;height:8px;border-radius:50%;background:var(--red,#ff2a45);color:var(--red,#ff2a45);"></span>
      </div>
      <span style="margin-top:22px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.16em;color:var(--muted,#7c7e8a);">03 / VERTICAL</span>
      <h3 style="margin:9px 0 0;font-size:19px;font-weight:600;line-height:1.2;">Custom LED Installations</h3>
      <p style="margin:11px 0 16px;font-size:13px;line-height:1.55;color:var(--muted,#9a9aa2);flex:1;">Large-scale addressable RGB builds — pixel-mapped, sound-reactive and choreographed in real time.</p>
      <div style="display:flex;flex-wrap:wrap;gap:7px;">
        <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.06em;color:var(--muted,#9a9aa2);border:1px solid var(--line,#23242e);padding:5px 9px;border-radius:3px;">ADDRESSABLE&nbsp;RGB</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.06em;color:var(--muted,#9a9aa2);border:1px solid var(--line,#23242e);padding:5px 9px;border-radius:3px;">SOUND&nbsp;REACTIVE</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.06em;color:var(--muted,#9a9aa2);border:1px solid var(--line,#23242e);padding:5px 9px;border-radius:3px;">MAPPING</span>
      </div>
    </div>

    <div data-card data-reveal style="position:relative;display:flex;flex-direction:column;border:1px solid var(--line,#23242e);background:var(--panel,#0c0d11);border-radius:6px;padding:24px 22px;overflow:hidden;">
      <span style="position:absolute;left:0;top:0;bottom:0;width:3px;background-image:repeating-linear-gradient(180deg,var(--red,#ff2a45) 0 7px,transparent 7px 13px);box-shadow:0 0 8px var(--red,#ff2a45);opacity:.5;"></span>
      <div style="display:flex;align-items:flex-start;justify-content:space-between;">
        <div style="display:grid;grid-template-columns:repeat(3,9px);gap:7px;">
          <span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span>
          <span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--ledoff,#15161d);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span>
          <span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span><span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 7px var(--red,#ff2a45);"></span>
        </div>
        <span data-corner style="width:8px;height:8px;border-radius:50%;background:var(--red,#ff2a45);color:var(--red,#ff2a45);"></span>
      </div>
      <span style="margin-top:22px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.16em;color:var(--muted,#7c7e8a);">04 / VERTICAL</span>
      <h3 style="margin:9px 0 0;font-size:19px;font-weight:600;line-height:1.2;">Experiential Events</h3>
      <p style="margin:11px 0 16px;font-size:13px;line-height:1.55;color:var(--muted,#9a9aa2);flex:1;">Interactive, sensor-driven moments — projection mapping and show control that pull a whole crowd into the work.</p>
      <div style="display:flex;flex-wrap:wrap;gap:7px;">
        <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.06em;color:var(--muted,#9a9aa2);border:1px solid var(--line,#23242e);padding:5px 9px;border-radius:3px;">PROJECTION&nbsp;MAPPING</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.06em;color:var(--muted,#9a9aa2);border:1px solid var(--line,#23242e);padding:5px 9px;border-radius:3px;">SENSORS</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.06em;color:var(--muted,#9a9aa2);border:1px solid var(--line,#23242e);padding:5px 9px;border-radius:3px;">SHOW&nbsp;CONTROL</span>
      </div>
    </div>

  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px 80px;margin-top:64px;">
    <div data-reveal style="display:flex;flex-direction:column;gap:22px;">
      <div style="display:flex;flex-direction:column;gap:11px;">
        <span style="display:flex;align-items:center;gap:8px;font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.18em;color:var(--muted,#7c7e8a);"><span style="width:6px;height:6px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 6px var(--red,#ff2a45);"></span>SOFTWARE</span>
        <div style="display:flex;flex-wrap:wrap;gap:9px;">
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">JavaScript</span>
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">Three.js / GLSL</span>
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">C / C++</span>
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">Vibe Coding</span>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:11px;">
        <span style="display:flex;align-items:center;gap:8px;font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.18em;color:var(--muted,#7c7e8a);"><span style="width:6px;height:6px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 6px var(--red,#ff2a45);"></span>FABRICATION</span>
        <div style="display:flex;flex-wrap:wrap;gap:9px;">
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">Laser Cutting</span>
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">CNC Milling</span>
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">3D Printing</span>
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">PCB / KiCad</span>
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">Soldering / SMD</span>
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">Arduino / ESP32</span>
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">CAD / Fusion 360</span>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:11px;">
        <span style="display:flex;align-items:center;gap:8px;font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.18em;color:var(--muted,#7c7e8a);"><span style="width:6px;height:6px;border-radius:50%;background:var(--red,#ff2a45);box-shadow:0 0 6px var(--red,#ff2a45);"></span>BUILD</span>
        <div style="display:flex;flex-wrap:wrap;gap:9px;">
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">LED Installation</span>
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">Pixel Mapping</span>
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">Event Production</span>
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">Rigging / Power</span>
          <span data-hov style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.08em;border:1px solid var(--line,#23242e);padding:8px 12px;border-radius:4px;color:var(--ink,#f3f4f8);">On-site Install</span>
        </div>
      </div>
    </div>
    <div data-reveal style="display:flex;flex-direction:column;gap:18px;">
      <span style="font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.18em;color:var(--muted,#7c7e8a);">LIVE&nbsp;RGB&nbsp;MATRIX</span>
      <canvas data-grid-canvas style="width:100%;flex:1;min-height:180px;border:1px solid var(--line,#23242e);border-radius:4px;background:#020203;"></canvas>
    </div>
  </div>

  <figure data-reveal style="margin:64px 0 0;border-top:1px solid var(--line,#23242e);padding:40px 0 0;display:flex;flex-direction:column;align-items:center;text-align:center;gap:18px;">
    <span style="width:9px;height:9px;border-radius:50%;background:var(--red,#ff2a45);color:var(--red,#ff2a45);box-shadow:0 0 10px var(--red,#ff2a45);animation:ledPulse 1.6s infinite;"></span>
    <blockquote style="margin:0;max-width:760px;font-size:clamp(20px,2.6vw,32px);font-weight:600;line-height:1.3;letter-spacing:-.01em;color:var(--ink,#f3f4f8);text-wrap:balance;">“A jack of all trades is a master of none, but <span style="color:var(--red,#ff2a45);text-shadow:0 0 18px var(--red,#ff2a45);">oftentimes better</span> than a master of one.”</blockquote>
    <figcaption style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.16em;color:var(--muted,#7c7e8a);">ANONYMOUS PROVERB — OFTEN MISQUOTED</figcaption>
    <p style="margin:6px 0 0;max-width:600px;font-size:15px;line-height:1.6;color:var(--muted,#9a9aa2);">I'm a generalist by design. Schematic to firmware, CAD to CNC, pixels to live events — living in the gaps between disciplines is exactly where the most interesting things get built.</p>
  </figure>
</section>
